#!/bin/sh
# bbd-backup: backup and restore bandwidth history to/from a remote server.
# Usage: bbd-backup backup | bbd-backup restore

PERSIST_DIR="/etc/bandwidthbydevice"
RUNTIME_DIR="/tmp/bandwidthbydevice"
STATUS_FILE="$RUNTIME_DIR/backup_status.json"
ARCHIVE_NAME="bandwidth_backup.tar.gz"

mkdir -p "$RUNTIME_DIR"

cfg() { uci -q get "bandwidthbydevice.backup.$1"; }

write_status() {
    local status="$1" msg="$2"
    printf '{"status":"%s","message":"%s","ts":%d}\n' \
        "$status" "$msg" "$(date +%s)" > "$STATUS_FILE"
}

# Write credentials to a temp netrc file so they never appear in process list
make_netrc() {
    local host="$1" user="$2" pass="$3"
    local f
    f=$(mktemp)
    chmod 600 "$f"
    printf 'machine %s\nlogin %s\npassword %s\n' "$host" "$user" "$pass" > "$f"
    echo "$f"
}

do_backup() {
    local proto host port user pass path
    proto=$(cfg protocol); proto=${proto:-sftp}
    host=$(cfg host)
    port=$(cfg port);      port=${port:-22}
    user=$(cfg username)
    pass=$(cfg password)
    path=$(cfg remote_path); path=${path:-/backup/bandwidthbydevice}

    [ -z "$host" ] && { write_status "error" "No host configured"; exit 1; }
    [ -z "$user" ] && { write_status "error" "No username configured"; exit 1; }

    local archive
    archive=$(mktemp /tmp/bbd-backup-XXXXXX.tar.gz)

    tar -czf "$archive" -C "$PERSIST_DIR" . 2>/dev/null || {
        rm -f "$archive"
        write_status "error" "Failed to create archive"
        exit 1
    }

    local rc output
    case "$proto" in
      sftp)
        local netrc
        netrc=$(make_netrc "$host" "$user" "$pass")
        output=$(curl -s --netrc-file "$netrc" --ftp-create-dirs \
            "sftp://${host}:${port}${path}/${ARCHIVE_NAME}" \
            -T "$archive" 2>&1)
        rc=$?
        rm -f "$netrc"
        ;;
      scp)
        if ! which sshpass >/dev/null 2>&1; then
            rm -f "$archive"
            write_status "error" "sshpass not installed — run: opkg install sshpass"
            exit 1
        fi
        output=$(sshpass -p "$pass" scp \
            -P "$port" -o StrictHostKeyChecking=no -o BatchMode=no \
            "$archive" "${user}@${host}:${path}/${ARCHIVE_NAME}" 2>&1)
        rc=$?
        ;;
      *)
        rm -f "$archive"
        write_status "error" "Unknown protocol: $proto"
        exit 1
        ;;
    esac

    rm -f "$archive"

    if [ "$rc" -eq 0 ]; then
        write_status "ok" "Backup completed — $(date '+%Y-%m-%d %H:%M:%S')"
    else
        write_status "error" "Transfer failed: $output"
        exit 1
    fi
}

do_restore() {
    local proto host port user pass path
    proto=$(cfg protocol); proto=${proto:-sftp}
    host=$(cfg host)
    port=$(cfg port);      port=${port:-22}
    user=$(cfg username)
    pass=$(cfg password)
    path=$(cfg remote_path); path=${path:-/backup/bandwidthbydevice}

    [ -z "$host" ] && { write_status "error" "No host configured"; exit 1; }

    local archive
    archive=$(mktemp /tmp/bbd-restore-XXXXXX.tar.gz)

    local rc output
    case "$proto" in
      sftp)
        local netrc
        netrc=$(make_netrc "$host" "$user" "$pass")
        output=$(curl -s --netrc-file "$netrc" \
            "sftp://${host}:${port}${path}/${ARCHIVE_NAME}" \
            -o "$archive" 2>&1)
        rc=$?
        rm -f "$netrc"
        ;;
      scp)
        if ! which sshpass >/dev/null 2>&1; then
            rm -f "$archive"
            write_status "error" "sshpass not installed — run: opkg install sshpass"
            exit 1
        fi
        output=$(sshpass -p "$pass" scp \
            -P "$port" -o StrictHostKeyChecking=no -o BatchMode=no \
            "${user}@${host}:${path}/${ARCHIVE_NAME}" "$archive" 2>&1)
        rc=$?
        ;;
      *)
        rm -f "$archive"
        write_status "error" "Unknown protocol: $proto"
        exit 1
        ;;
    esac

    if [ "$rc" -ne 0 ]; then
        rm -f "$archive"
        write_status "error" "Download failed: $output"
        exit 1
    fi

    mkdir -p "$PERSIST_DIR"
    tar -xzf "$archive" -C "$PERSIST_DIR" 2>/dev/null
    rc=$?
    rm -f "$archive"

    if [ "$rc" -eq 0 ]; then
        write_status "ok" "Restore completed — $(date '+%Y-%m-%d %H:%M:%S')"
    else
        write_status "error" "Failed to extract backup archive"
        exit 1
    fi
}

case "$1" in
  backup)  do_backup  ;;
  restore) do_restore ;;
  *) echo "Usage: $0 backup|restore"; exit 1 ;;
esac
