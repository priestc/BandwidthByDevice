#!/bin/sh
# bbd-backup: remote persistence for bandwidth history.
# Usage: bbd-backup hourly

PERSIST_DIR="/etc/bandwidthbydevice"
RUNTIME_DIR="/tmp/bandwidthbydevice"
STATUS_FILE="$RUNTIME_DIR/backup_status.json"
DEVICES_FILE="$PERSIST_DIR/known_devices"

mkdir -p "$RUNTIME_DIR"

cfg() { uci -q get "bandwidthbydevice.backup.$1"; }

write_status() {
    local status="$1" msg="$2"
    msg=$(printf '%s' "$msg" | tr -d '\r\n' | sed 's/\\/\\\\/g; s/"/\\"/g')
    printf '{"status":"%s","message":"%s","ts":%d}\n' \
        "$status" "$msg" "$(date +%s)" > "$STATUS_FILE"
}

do_hourly() {
    local host port user pass path
    host=$(cfg host);     [ -z "$host" ] && { write_status "error" "No host configured"; exit 1; }
    port=$(cfg port);     port=${port:-22}
    user=$(cfg username); [ -z "$user" ] && { write_status "error" "No username configured"; exit 1; }
    pass=$(cfg password)
    path=$(cfg remote_path); path="${path%/}"

    if ! which sshpass >/dev/null 2>&1; then
        write_status "error" "sshpass not installed — run: opkg install sshpass"
        exit 1
    fi

    [ -f "$DEVICES_FILE" ] || { write_status "error" "No device data available"; exit 1; }

    local ts
    ts=$(date +%s)

    # Label the hour that just completed
    local period
    period=$(awk "BEGIN{print strftime(\"%Y-%m-%dT%H:00\", $ts - 3600)}")

    local tmpfile
    tmpfile=$(mktemp /tmp/bbd-persist-XXXXXX)

    while IFS=' ' read -r mac ip hostname; do
        [ -z "$mac" ] && continue
        local safemac
        safemac=$(echo "$mac" | tr -d ':')

        local statfile="$RUNTIME_DIR/stats_${safemac}.json"
        local down=0 up=0
        if [ -f "$statfile" ]; then
            down=$(grep -o '"down":[0-9]*' "$statfile" | awk -F: '{s+=$2}END{print s+0}')
            up=$(  grep -o '"up":[0-9]*'   "$statfile" | awk -F: '{s+=$2}END{print s+0}')
        fi

        # Skip devices with no activity this hour
        [ "${down:-0}" -eq 0 ] && [ "${up:-0}" -eq 0 ] && continue

        printf '{"ts":%d,"period":"%s","mac":"%s","hostname":"%s","bytes_in":%s,"bytes_out":%s}\n' \
            "$ts" "$period" "$mac" "$hostname" "$down" "$up" >> "$tmpfile"
    done < "$DEVICES_FILE"

    local dest_file dir_dest
    dest_file="${path:+${path}/}BandwidthByDevice_OpenWRT.jsonl"
    dir_dest=$(dirname "$dest_file")

    # Ensure remote directory exists, then append new records to the history file
    sshpass -p "$pass" ssh \
        -p "$port" -o StrictHostKeyChecking=no \
        "${user}@${host}" "mkdir -p '${dir_dest}'" >/dev/null 2>&1

    local rc output
    output=$(sshpass -p "$pass" ssh \
        -p "$port" -o StrictHostKeyChecking=no \
        "${user}@${host}" "cat >> '${dest_file}'" < "$tmpfile" 2>&1)
    rc=$?
    rm -f "$tmpfile"

    if [ "$rc" -eq 0 ]; then
        write_status "ok" "Appended ${period} to ${user}@${host}:${dest_file} — $(date '+%Y-%m-%d %H:%M:%S')"
    else
        write_status "error" "Persistence failed: $output"
        exit 1
    fi
}

case "$1" in
  hourly) do_hourly ;;
  *) echo "Usage: $0 hourly"; exit 1 ;;
esac
