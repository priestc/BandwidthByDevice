#!/bin/sh
#
# bbd-collector: Per-device bandwidth data collection daemon.
#
# Uses nftables (nft) in the inet family so IPv4 and IPv6 are both tracked
# without requiring ip6tables (which is not installed on many OpenWRT builds).
#
# Download: BBD_IN chain, FORWARD hook priority 1.  FORWARD runs after
#           nat PREROUTING (where DNAT resolves the real LAN IP), and
#           priority 1 puts us just after fw4's filter chain (priority 0)
#           so we only count traffic that fw4 actually forwarded.
#
# Upload:   BBD_OUT chain, PREROUTING hook priority -150 (mangle priority).
#           The device's source IP is still its LAN address at PREROUTING
#           — MASQUERADE/SNAT is applied later at POSTROUTING.
#
# Byte counters in nft are cumulative; we compute per-interval deltas by
# storing the last-read value per address in /tmp so no counter reset is
# needed and no data is lost on slow reads.

INTERVAL=10
RUNTIME_DIR="/tmp/bandwidthbydevice"
PERSIST_DIR="/etc/bandwidthbydevice"
DEVICES_FILE="$PERSIST_DIR/known_devices"
CHAIN_IN="BBD_IN"
CHAIN_OUT="BBD_OUT"
NFT_PREV_DIR="$RUNTIME_DIR/nft_prev"
PERSIST_BUF="$RUNTIME_DIR/persist_buf.jsonl"
INTERVAL_FILE="$RUNTIME_DIR/interval"
WAN_IFACE=""

mkdir -p "$RUNTIME_DIR" "$PERSIST_DIR" "$NFT_PREV_DIR"

# Seed interval from uci config; rpcd set_interval updates INTERVAL_FILE at runtime.
_cfg_interval=$(uci -q get bandwidthbydevice.sampling.interval 2>/dev/null)
INTERVAL=${_cfg_interval:-$INTERVAL}
printf '%d\n' "$INTERVAL" > "$INTERVAL_FILE"

log() { logger -t bbd-collector "$*"; }

# ---- WAN interface detection ------------------------------------------------

get_wan_iface() {
    ip route show default 2>/dev/null \
        | awk 'NR==1 { for(i=1;i<=NF;i++) if($i=="dev") { print $(i+1); exit } }'
}

# ---- nftables helpers -------------------------------------------------------

setup_nft() {
    nft add table inet bbd 2>/dev/null
    nft "add chain inet bbd $CHAIN_IN { type filter hook forward priority 1; }" 2>/dev/null
    nft "add chain inet bbd $CHAIN_OUT { type filter hook prerouting priority -150; }" 2>/dev/null
}

teardown_nft() {
    nft flush table inet bbd 2>/dev/null
    nft delete table inet bbd 2>/dev/null
}

# Add a download (BBD_IN) rule for an IPv4 address if one doesn't exist yet.
# Checks against the cached chain output written at the top of each loop.
ensure_nft_ip4_in() {
    local ip="$1"
    grep -qF "ip daddr $ip counter" "$RUNTIME_DIR/nft_in_cache" 2>/dev/null && return
    if [ -n "$WAN_IFACE" ]; then
        nft add rule inet bbd "$CHAIN_IN" iifname "$WAN_IFACE" ip daddr "$ip" counter 2>/dev/null
    else
        nft add rule inet bbd "$CHAIN_IN" ip daddr "$ip" counter 2>/dev/null
    fi
}

ensure_nft_ip4_out() {
    local ip="$1"
    grep -qF "ip saddr $ip counter" "$RUNTIME_DIR/nft_out_cache" 2>/dev/null && return
    nft add rule inet bbd "$CHAIN_OUT" ip saddr "$ip" counter 2>/dev/null
}

ensure_nft_ip6_in() {
    local ip6="$1"
    grep -qF "ip6 daddr $ip6 counter" "$RUNTIME_DIR/nft_in_cache" 2>/dev/null && return
    if [ -n "$WAN_IFACE" ]; then
        nft add rule inet bbd "$CHAIN_IN" iifname "$WAN_IFACE" ip6 daddr "$ip6" counter 2>/dev/null
    else
        nft add rule inet bbd "$CHAIN_IN" ip6 daddr "$ip6" counter 2>/dev/null
    fi
}

ensure_nft_ip6_out() {
    local ip6="$1"
    grep -qF "ip6 saddr $ip6 counter" "$RUNTIME_DIR/nft_out_cache" 2>/dev/null && return
    nft add rule inet bbd "$CHAIN_OUT" ip6 saddr "$ip6" counter 2>/dev/null
}

# ---- device discovery -------------------------------------------------------

get_arp_devices() {
    awk 'NR>1 && $3=="0x2" {print $1, $4}' /proc/net/arp
}

get_ndp_devices() {
    ip -6 neigh show 2>/dev/null | awk '
        /lladdr/ {
            if ($1 ~ /^fe80:/) next
            state = $NF
            if (state == "FAILED" || state == "INCOMPLETE") next
            for (i = 1; i <= NF; i++)
                if ($i == "lladdr") { mac = $(i+1); break }
            if (mac != "" && mac != "00:00:00:00:00:00")
                print $1, mac
        }'
}

get_hostname() {
    local ip="$1"
    local name
    name=$(awk -v ip="$ip" '$3==ip {print $4; exit}' /tmp/dhcp.leases 2>/dev/null)
    [ -n "$name" ] && [ "$name" != "*" ] && echo "$name" && return
    echo "$ip"
}

# ---- device registry --------------------------------------------------------

update_known_devices() {
    local tmpfile="$DEVICES_FILE.tmp"
    [ -f "$DEVICES_FILE" ] && cp "$DEVICES_FILE" "$tmpfile" || touch "$tmpfile"

    while IFS=' ' read -r ip mac; do
        [ -z "$ip" ] || [ -z "$mac" ] && continue
        local hostname
        hostname=$(get_hostname "$ip")
        grep -v "^$mac " "$tmpfile" > "${tmpfile}.2" 2>/dev/null \
            && mv "${tmpfile}.2" "$tmpfile"
        printf '%s %s %s\n' "$mac" "$ip" "$hostname" >> "$tmpfile"
    done < "$RUNTIME_DIR/arp_snapshot"

    mv "$tmpfile" "$DEVICES_FILE"
}

# ---- delta-based byte reading -----------------------------------------------

# Sanitize an IP address for use as a filename component.
safe_addr() { printf '%s' "$1" | tr '.:' '__'; }

# Read the cumulative byte counter for $addr from a cached nft chain file,
# compute the delta since the last call, persist the new baseline, and
# print the delta.  Handles counter resets (e.g. after service restart)
# by treating a decrease as "start fresh from current value".
get_bytes_delta() {
    local cache_file="$1" addr="$2" dir="$3"
    local safaddr prev_file current prev delta

    safaddr=$(safe_addr "$addr")
    prev_file="$NFT_PREV_DIR/${dir}_${safaddr}"

    current=$(awk -v a="$addr" '
        index($0, " " a " counter") {
            for (i=1; i<=NF; i++) if ($i=="bytes") { print $(i+1); exit }
        }' "$cache_file" 2>/dev/null)
    current=${current:-0}

    if [ -f "$prev_file" ]; then
        read -r prev < "$prev_file"
        prev=${prev:-0}
        if [ "$current" -ge "$prev" ] 2>/dev/null; then
            delta=$(awk "BEGIN{print $current - $prev}")
        else
            delta="$current"
        fi
    else
        delta="$current"
    fi

    printf '%s\n' "$current" > "$prev_file"
    printf '%s\n' "$delta"
}

# ---- JSON helpers -----------------------------------------------------------

bytes_to_human() {
    local b="$1"
    if   [ "$b" -gt 1073741824 ]; then printf "%.2f GB" "$(echo "$b 1073741824" | awk '{printf "%.2f", $1/$2}')";
    elif [ "$b" -gt 1048576 ];    then printf "%.2f MB" "$(echo "$b 1048576"    | awk '{printf "%.2f", $1/$2}')";
    elif [ "$b" -gt 1024 ];       then printf "%.2f KB" "$(echo "$b 1024"       | awk '{printf "%.2f", $1/$2}')";
    else printf "%d B" "$b"; fi
}

write_current_json() {
    [ -f "$DEVICES_FILE" ] || return
    local tmpfile="$RUNTIME_DIR/current.json.tmp"
    local ts
    ts=$(date +%s)

    printf '{"ts":%d,"devices":[' "$ts" > "$tmpfile"
    local first=1
    while IFS=' ' read -r mac ip hostname; do
        [ -z "$mac" ] && continue
        local safemac
        safemac=$(echo "$mac" | tr -d ':')

        local active_ip
        active_ip=$(awk -v m="$mac" '$2==m {print $1; exit}' "$RUNTIME_DIR/arp_snapshot")

        local down=0 up=0 active="false"

        # IPv4 bytes
        if [ -n "$active_ip" ]; then
            ip="$active_ip"
            hostname=$(get_hostname "$ip")
            down=$(get_bytes_delta "$RUNTIME_DIR/nft_in_cache"  "$ip" "in");  down=${down:-0}
            up=$(get_bytes_delta   "$RUNTIME_DIR/nft_out_cache" "$ip" "out"); up=${up:-0}
            active="true"
        fi

        # IPv6 bytes — sum all global addresses for this MAC
        if [ -f "$RUNTIME_DIR/ndp_snapshot" ]; then
            while IFS=' ' read -r ip6 mac6; do
                [ "$mac6" = "$mac" ] || continue
                active="true"
                local d6 u6
                d6=$(get_bytes_delta "$RUNTIME_DIR/nft_in_cache"  "$ip6" "in");  d6=${d6:-0}
                u6=$(get_bytes_delta "$RUNTIME_DIR/nft_out_cache" "$ip6" "out"); u6=${u6:-0}
                down=$(awk "BEGIN{print $down + $d6}")
                up=$(awk "BEGIN{print $up + $u6}")
            done < "$RUNTIME_DIR/ndp_snapshot"
        fi

        if [ "$active" = "true" ]; then
            append_sample "$safemac" "$ts" "$down" "$up"
            # Append non-zero intervals to the persistence buffer (tier-1 raw data).
            if [ "$down" -gt 0 ] 2>/dev/null || [ "$up" -gt 0 ] 2>/dev/null; then
                printf '{"ts":%d,"mac":"%s","hostname":"%s","down":%s,"up":%s}\n' \
                    "$ts" "$mac" "$hostname" "$down" "$up" >> "$PERSIST_BUF"
            fi
        fi

        # Hourly totals from the rolling stats buffer (used for device ordering).
        local hourly_down=0 hourly_up=0
        local statfile="$RUNTIME_DIR/stats_${safemac}.json"
        if [ -f "$statfile" ]; then
            hourly_down=$(grep -o '"down":[0-9]*' "$statfile" | awk -F: '{s+=$2}END{print s+0}')
            hourly_up=$(  grep -o '"up":[0-9]*'   "$statfile" | awk -F: '{s+=$2}END{print s+0}')
        fi

        # Track last-activity timestamp; update whenever there are non-zero bytes.
        local idle_secs=0
        local last_active_file="$RUNTIME_DIR/last_active_${safemac}"
        if [ "$down" -gt 0 ] 2>/dev/null || [ "$up" -gt 0 ] 2>/dev/null; then
            printf '%d\n' "$ts" > "$last_active_file"
        fi
        if [ -f "$last_active_file" ]; then
            local last_active_ts
            read -r last_active_ts < "$last_active_file"
            idle_secs=$((ts - last_active_ts))
            [ "$idle_secs" -lt 0 ] && idle_secs=0
        fi

        [ "$first" -eq 0 ] && printf ',' >> "$tmpfile"
        printf '{"ip":"%s","mac":"%s","hostname":"%s","down_bytes":%s,"up_bytes":%s,"hourly_down":%s,"hourly_up":%s,"active":%s,"idle_secs":%d}' \
            "$ip" "$mac" "$hostname" "$down" "$up" "$hourly_down" "$hourly_up" "$active" "$idle_secs" >> "$tmpfile"
        first=0
    done < "$DEVICES_FILE"
    printf ']}\n' >> "$tmpfile"

    mv "$tmpfile" "$RUNTIME_DIR/current.json"
}

# ---- daily accumulator (in /tmp, flushed to flash hourly) -------------------

update_daily_acc() {
    local safemac="$1" down="$2" up="$3"
    local today
    today=$(date +%Y-%m-%d)
    local accfile="$RUNTIME_DIR/daily_acc_${safemac}"

    local stored_date='' stored_down=0 stored_up=0
    if [ -f "$accfile" ]; then
        read -r stored_date stored_down stored_up < "$accfile"
    fi

    if [ "$stored_date" = "$today" ]; then
        stored_down=$(awk "BEGIN{print $stored_down + $down}")
        stored_up=$(awk "BEGIN{print $stored_up + $up}")
    else
        stored_down="$down"
        stored_up="$up"
    fi

    printf '%s %s %s\n' "$today" "$stored_down" "$stored_up" > "$accfile"
}

append_sample() {
    local safemac="$1" ts="$2" down="$3" up="$4"
    update_daily_acc "$safemac" "$down" "$up"
    local statfile="$RUNTIME_DIR/stats_${safemac}.json"
    local entry
    entry=$(printf '{"ts":%d,"down":%s,"up":%s}' "$ts" "$down" "$up")

    if [ ! -f "$statfile" ]; then
        printf '{"samples":[%s]}\n' "$entry" > "$statfile"
    else
        awk -v entry="$entry" '
        BEGIN { max=360 }
        {
            sub(/\]\}$/, "")
            sub(/^\{"samples":\[/, "")
            n = split($0, arr, /\},\{/)
            out = ""
            start = (n >= max) ? n - max + 1 : 1
            for (i=start; i<=n; i++) {
                if (out != "") out = out ","
                s = arr[i]
                if (substr(s,1,1) != "{") s = "{" s
                if (substr(s,length(s),1) != "}") s = s "}"
                out = out s
            }
            if (out != "") out = out "," entry
            else out = entry
            print "{\"samples\":[" out "]}"
        }' "$statfile" > "${statfile}.tmp" && mv "${statfile}.tmp" "$statfile"
    fi
}

# ---- daily persistence ------------------------------------------------------

persist_daily_totals() {
    [ -f "$DEVICES_FILE" ] || return
    local today
    today=$(date +%Y-%m-%d)
    while IFS=' ' read -r mac ip hostname; do
        [ -z "$mac" ] && continue
        local safemac
        safemac=$(echo "$mac" | tr -d ':')

        local accfile="$RUNTIME_DIR/daily_acc_${safemac}"
        [ -f "$accfile" ] || continue
        local stored_date stored_down stored_up
        read -r stored_date stored_down stored_up < "$accfile"
        [ "$stored_date" != "$today" ] && continue

        local histfile="$PERSIST_DIR/history_${safemac}.json"
        local entry
        entry=$(printf '{"date":"%s","down":%s,"up":%s}' "$today" "$stored_down" "$stored_up")

        if [ ! -f "$histfile" ]; then
            printf '{"daily":[%s]}\n' "$entry" > "$histfile"
        else
            awk -v today="$today" -v entry="$entry" '
            {
                sub(/\]\}$/, "")
                sub(/^\{"daily":\[/, "")
                n = split($0, arr, /\},\{/)
                found = 0
                out = ""
                for (i=1; i<=n; i++) {
                    s = arr[i]
                    if (substr(s,1,1) != "{") s = "{" s
                    if (substr(s,length(s),1) != "}") s = s "}"
                    if (index(s, "\"date\":\"" today "\"")) { s = entry; found = 1 }
                    if (out != "") out = out ","
                    out = out s
                }
                if (!found) { if (out != "") out = out ","; out = out entry }
                n2 = split(out, arr2, /\},\{/)
                start = (n2 > 90) ? n2 - 89 : 1
                out2 = ""
                for (i=start; i<=n2; i++) {
                    s = arr2[i]
                    if (substr(s,1,1) != "{") s = "{" s
                    if (substr(s,length(s),1) != "}") s = s "}"
                    if (out2 != "") out2 = out2 ","
                    out2 = out2 s
                }
                print "{\"daily\":[" out2 "]}"
            }' "$histfile" > "${histfile}.tmp" && mv "${histfile}.tmp" "$histfile"
        fi
    done < "$DEVICES_FILE"
}

# ---- persistence buffer flush trigger --------------------------------------

check_persist_flush() {
    [ -f "$PERSIST_BUF" ]              || return
    [ -f "$RUNTIME_DIR/flush.lock" ]   && return  # already flushing
    local limit_kb
    limit_kb=$(uci -q get bandwidthbydevice.persist.buf_limit_kb 2>/dev/null)
    limit_kb=${limit_kb:-2048}
    local size_bytes
    size_bytes=$(wc -c < "$PERSIST_BUF" 2>/dev/null)
    [ $((${size_bytes:-0} / 1024)) -ge "$limit_kb" ] && /usr/bin/bbd-backup flush &
}

# ---- main loop --------------------------------------------------------------

trap 'log "stopping"; teardown_nft; exit 0' TERM INT

WAN_IFACE=$(get_wan_iface)
log "starting (WAN: ${WAN_IFACE:-unknown})"
teardown_nft
setup_nft

# Seed empty cache files so ensure functions work on first iteration
: > "$RUNTIME_DIR/nft_in_cache"
: > "$RUNTIME_DIR/nft_out_cache"

DAILY_FLUSH_HOUR=-1

while true; do
    # Pick up interval changes written by rpcd set_interval without a restart
    if [ -f "$INTERVAL_FILE" ]; then
        read -r _ni < "$INTERVAL_FILE"
        [ -n "$_ni" ] && INTERVAL=$_ni
    fi

    # Rebuild download rules if WAN interface changed (e.g. PPPoE reconnect)
    new_wan=$(get_wan_iface)
    if [ "$new_wan" != "$WAN_IFACE" ]; then
        log "WAN changed: '${WAN_IFACE}' -> '${new_wan:-unknown}', flushing BBD_IN"
        nft flush chain inet bbd "$CHAIN_IN" 2>/dev/null
        : > "$RUNTIME_DIR/nft_in_cache"
        WAN_IFACE="$new_wan"
    fi

    # Snapshot current chain state — used for dedup checks and byte reading
    nft list chain inet bbd "$CHAIN_IN"  2>/dev/null > "$RUNTIME_DIR/nft_in_cache"
    nft list chain inet bbd "$CHAIN_OUT" 2>/dev/null > "$RUNTIME_DIR/nft_out_cache"

    # Refresh ARP snapshot, update device registry, add IPv4 rules
    get_arp_devices > "$RUNTIME_DIR/arp_snapshot"
    while IFS=' ' read -r ip mac; do
        [ -z "$ip" ] && continue
        ensure_nft_ip4_in  "$ip"
        ensure_nft_ip4_out "$ip"
    done < "$RUNTIME_DIR/arp_snapshot"
    update_known_devices

    # Refresh NDP snapshot, add IPv6 rules
    get_ndp_devices > "$RUNTIME_DIR/ndp_snapshot"
    while IFS=' ' read -r ip6 mac; do
        [ -z "$ip6" ] && continue
        ensure_nft_ip6_in  "$ip6"
        ensure_nft_ip6_out "$ip6"
    done < "$RUNTIME_DIR/ndp_snapshot"

    write_current_json

    # Persist daily totals once per hour (on the hour)
    current_hour=$(date +%H | sed 's/^0//')
    if [ "$current_hour" != "$DAILY_FLUSH_HOUR" ]; then
        persist_daily_totals
        DAILY_FLUSH_HOUR="$current_hour"
    fi

    check_persist_flush

    sleep "$INTERVAL"
done
