#!/bin/sh
#
# bbd-collector: Per-device bandwidth data collection daemon.
#
# Measurement strategy:
#   Rules live in mangle PREROUTING rather than filter FORWARD. OpenWRT's
#   software/hardware flow offloading bypasses filter FORWARD for established
#   connections, but mangle PREROUTING fires for every packet regardless.
#   After conntrack resolves DNAT, the real LAN destination IP is visible here.
#
#   Download: -i $WAN_IFACE -d $device_ip  (WAN→device, post-DNAT resolve)
#   Upload:   -s $device_ip                (device→anywhere; LAN IPs are
#                                           unique so no interface filter needed)
#
#   IPv6 traffic is tracked via identical ip6tables chains; both v4 and v6
#   byte counts are summed per device each interval.

INTERVAL=10
RUNTIME_DIR="/tmp/bandwidthbydevice"
PERSIST_DIR="/etc/bandwidthbydevice"
DEVICES_FILE="$PERSIST_DIR/known_devices"
CHAIN_IN="BBD_IN"
CHAIN_OUT="BBD_OUT"
WAN_IFACE=""
WAN_IFACE6=""

mkdir -p "$RUNTIME_DIR" "$PERSIST_DIR"

log() { logger -t bbd-collector "$*"; }

# ---- WAN interface detection ------------------------------------------------

get_wan_iface() {
    ip route show default 2>/dev/null \
        | awk 'NR==1 { for(i=1;i<=NF;i++) if($i=="dev") { print $(i+1); exit } }'
}

get_wan_iface6() {
    ip -6 route show default 2>/dev/null \
        | awk 'NR==1 { for(i=1;i<=NF;i++) if($i=="dev") { print $(i+1); exit } }'
}

# ---- iptables helpers -------------------------------------------------------

setup_chains() {
    iptables -t mangle -N "$CHAIN_IN"  2>/dev/null
    iptables -t mangle -N "$CHAIN_OUT" 2>/dev/null
    iptables -t mangle -C PREROUTING -j "$CHAIN_IN"  2>/dev/null || \
        iptables -t mangle -I PREROUTING 1 -j "$CHAIN_IN"
    iptables -t mangle -C PREROUTING -j "$CHAIN_OUT" 2>/dev/null || \
        iptables -t mangle -I PREROUTING 2 -j "$CHAIN_OUT"
}

teardown_chains() {
    # Mangle table (current)
    iptables -t mangle -D PREROUTING -j "$CHAIN_IN"  2>/dev/null
    iptables -t mangle -D PREROUTING -j "$CHAIN_OUT" 2>/dev/null
    iptables -t mangle -F "$CHAIN_IN"  2>/dev/null
    iptables -t mangle -F "$CHAIN_OUT" 2>/dev/null
    iptables -t mangle -X "$CHAIN_IN"  2>/dev/null
    iptables -t mangle -X "$CHAIN_OUT" 2>/dev/null
    # Filter table (legacy cleanup from older deployments)
    iptables -D FORWARD -j "$CHAIN_IN"  2>/dev/null
    iptables -D FORWARD -j "$CHAIN_OUT" 2>/dev/null
    iptables -F "$CHAIN_IN"  2>/dev/null
    iptables -F "$CHAIN_OUT" 2>/dev/null
    iptables -X "$CHAIN_IN"  2>/dev/null
    iptables -X "$CHAIN_OUT" 2>/dev/null
}

ensure_rules_for_ip() {
    local ip="$1"
    if [ -n "$WAN_IFACE" ]; then
        iptables -t mangle -C "$CHAIN_IN" -i "$WAN_IFACE" -d "$ip" 2>/dev/null || \
            iptables -t mangle -A "$CHAIN_IN" -i "$WAN_IFACE" -d "$ip" -j RETURN
    else
        iptables -t mangle -C "$CHAIN_IN" -d "$ip" 2>/dev/null || \
            iptables -t mangle -A "$CHAIN_IN" -d "$ip" -j RETURN
    fi
    iptables -t mangle -C "$CHAIN_OUT" -s "$ip" 2>/dev/null || \
        iptables -t mangle -A "$CHAIN_OUT" -s "$ip" -j RETURN
}

# ---- ip6tables helpers ------------------------------------------------------

setup_chains6() {
    ip6tables -t mangle -N "$CHAIN_IN"  2>/dev/null
    ip6tables -t mangle -N "$CHAIN_OUT" 2>/dev/null
    ip6tables -t mangle -C PREROUTING -j "$CHAIN_IN"  2>/dev/null || \
        ip6tables -t mangle -I PREROUTING 1 -j "$CHAIN_IN"
    ip6tables -t mangle -C PREROUTING -j "$CHAIN_OUT" 2>/dev/null || \
        ip6tables -t mangle -I PREROUTING 2 -j "$CHAIN_OUT"
}

teardown_chains6() {
    ip6tables -t mangle -D PREROUTING -j "$CHAIN_IN"  2>/dev/null
    ip6tables -t mangle -D PREROUTING -j "$CHAIN_OUT" 2>/dev/null
    ip6tables -t mangle -F "$CHAIN_IN"  2>/dev/null
    ip6tables -t mangle -F "$CHAIN_OUT" 2>/dev/null
    ip6tables -t mangle -X "$CHAIN_IN"  2>/dev/null
    ip6tables -t mangle -X "$CHAIN_OUT" 2>/dev/null
}

ensure_rules_for_ip6() {
    local ip6="$1"
    if [ -n "$WAN_IFACE6" ]; then
        ip6tables -t mangle -C "$CHAIN_IN" -i "$WAN_IFACE6" -d "$ip6" 2>/dev/null || \
            ip6tables -t mangle -A "$CHAIN_IN" -i "$WAN_IFACE6" -d "$ip6" -j RETURN
    else
        ip6tables -t mangle -C "$CHAIN_IN" -d "$ip6" 2>/dev/null || \
            ip6tables -t mangle -A "$CHAIN_IN" -d "$ip6" -j RETURN
    fi
    ip6tables -t mangle -C "$CHAIN_OUT" -s "$ip6" 2>/dev/null || \
        ip6tables -t mangle -A "$CHAIN_OUT" -s "$ip6" -j RETURN
}

# ---- device discovery -------------------------------------------------------

get_arp_devices() {
    awk 'NR>1 && $3=="0x2" {print $1, $4}' /proc/net/arp
}

get_ndp_devices() {
    ip -6 neigh show 2>/dev/null | awk '
        /lladdr/ {
            if ($1 ~ /^fe80:/) next
            state = $NF
            if (state == "FAILED" || state == "INCOMPLETE") next
            for (i = 1; i <= NF; i++)
                if ($i == "lladdr") { mac = $(i+1); break }
            if (mac != "" && mac != "00:00:00:00:00:00")
                print $1, mac
        }'
}

get_hostname() {
    local ip="$1"
    local name
    name=$(awk -v ip="$ip" '$3==ip {print $4; exit}' /tmp/dhcp.leases 2>/dev/null)
    [ -n "$name" ] && [ "$name" != "*" ] && echo "$name" && return
    echo "$ip"
}

# ---- device registry --------------------------------------------------------

update_known_devices() {
    local tmpfile="$DEVICES_FILE.tmp"
    [ -f "$DEVICES_FILE" ] && cp "$DEVICES_FILE" "$tmpfile" || touch "$tmpfile"

    while IFS=' ' read -r ip mac; do
        [ -z "$ip" ] || [ -z "$mac" ] && continue
        local hostname
        hostname=$(get_hostname "$ip")
        grep -v "^$mac " "$tmpfile" > "${tmpfile}.2" 2>/dev/null \
            && mv "${tmpfile}.2" "$tmpfile"
        printf '%s %s %s\n' "$mac" "$ip" "$hostname" >> "$tmpfile"
    done < "$RUNTIME_DIR/arp_snapshot"

    mv "$tmpfile" "$DEVICES_FILE"
}

# ---- counter reading --------------------------------------------------------

read_bytes_for_ip() {
    local chain="$1" ip="$2"
    iptables -t mangle -nvxL "$chain" 2>/dev/null \
        | awk -v ip="$ip" '$8==ip || $9==ip {print $2; exit}'
}

read_bytes_for_ip6() {
    local chain="$1" ip6="$2"
    ip6tables -t mangle -nvxL "$chain" 2>/dev/null \
        | awk -v ip="$ip6" '$8==ip || $9==ip {print $2; exit}'
}

# ---- JSON helpers -----------------------------------------------------------

bytes_to_human() {
    local b="$1"
    if   [ "$b" -gt 1073741824 ]; then printf "%.2f GB" "$(echo "$b 1073741824" | awk '{printf "%.2f", $1/$2}')";
    elif [ "$b" -gt 1048576 ];    then printf "%.2f MB" "$(echo "$b 1048576"    | awk '{printf "%.2f", $1/$2}')";
    elif [ "$b" -gt 1024 ];       then printf "%.2f KB" "$(echo "$b 1024"       | awk '{printf "%.2f", $1/$2}')";
    else printf "%d B" "$b"; fi
}

write_current_json() {
    [ -f "$DEVICES_FILE" ] || return
    local tmpfile="$RUNTIME_DIR/current.json.tmp"
    local ts
    ts=$(date +%s)

    printf '{"ts":%d,"devices":[' "$ts" > "$tmpfile"
    local first=1
    while IFS=' ' read -r mac ip hostname; do
        [ -z "$mac" ] && continue
        local safemac
        safemac=$(echo "$mac" | tr -d ':')

        local active_ip
        active_ip=$(awk -v m="$mac" '$2==m {print $1; exit}' "$RUNTIME_DIR/arp_snapshot")

        local down=0 up=0 active="false"

        # IPv4 bytes
        if [ -n "$active_ip" ]; then
            ip="$active_ip"
            hostname=$(get_hostname "$ip")
            down=$(read_bytes_for_ip "$CHAIN_IN"  "$ip"); down=${down:-0}
            up=$(read_bytes_for_ip   "$CHAIN_OUT" "$ip"); up=${up:-0}
            active="true"
        fi

        # IPv6 bytes — sum all global addresses for this MAC
        if [ -f "$RUNTIME_DIR/ndp_snapshot" ]; then
            while IFS=' ' read -r ip6 mac6; do
                [ "$mac6" = "$mac" ] || continue
                active="true"
                local d6 u6
                d6=$(read_bytes_for_ip6 "$CHAIN_IN"  "$ip6"); d6=${d6:-0}
                u6=$(read_bytes_for_ip6 "$CHAIN_OUT" "$ip6"); u6=${u6:-0}
                down=$(awk "BEGIN{print $down + $d6}")
                up=$(awk "BEGIN{print $up + $u6}")
            done < "$RUNTIME_DIR/ndp_snapshot"
        fi

        if [ "$active" = "true" ]; then
            append_sample "$safemac" "$ts" "$down" "$up"
        fi

        [ "$first" -eq 0 ] && printf ',' >> "$tmpfile"
        printf '{"ip":"%s","mac":"%s","hostname":"%s","down_bytes":%s,"up_bytes":%s,"active":%s}' \
            "$ip" "$mac" "$hostname" "$down" "$up" "$active" >> "$tmpfile"
        first=0
    done < "$DEVICES_FILE"
    printf ']}\n' >> "$tmpfile"

    mv "$tmpfile" "$RUNTIME_DIR/current.json"
}

# ---- daily accumulator (in /tmp, flushed to flash hourly) -------------------

update_daily_acc() {
    local safemac="$1" down="$2" up="$3"
    local today
    today=$(date +%Y-%m-%d)
    local accfile="$RUNTIME_DIR/daily_acc_${safemac}"

    local stored_date='' stored_down=0 stored_up=0
    if [ -f "$accfile" ]; then
        read -r stored_date stored_down stored_up < "$accfile"
    fi

    if [ "$stored_date" = "$today" ]; then
        stored_down=$(awk "BEGIN{print $stored_down + $down}")
        stored_up=$(awk "BEGIN{print $stored_up + $up}")
    else
        stored_down="$down"
        stored_up="$up"
    fi

    printf '%s %s %s\n' "$today" "$stored_down" "$stored_up" > "$accfile"
}

append_sample() {
    local safemac="$1" ts="$2" down="$3" up="$4"
    update_daily_acc "$safemac" "$down" "$up"
    local statfile="$RUNTIME_DIR/stats_${safemac}.json"
    local entry
    entry=$(printf '{"ts":%d,"down":%s,"up":%s}' "$ts" "$down" "$up")

    if [ ! -f "$statfile" ]; then
        printf '{"samples":[%s]}\n' "$entry" > "$statfile"
    else
        awk -v entry="$entry" '
        BEGIN { max=360 }
        {
            sub(/\]\}$/, "")
            sub(/^\{"samples":\[/, "")
            n = split($0, arr, /\},\{/)
            out = ""
            start = (n >= max) ? n - max + 1 : 1
            for (i=start; i<=n; i++) {
                if (out != "") out = out ","
                s = arr[i]
                if (substr(s,1,1) != "{") s = "{" s
                if (substr(s,length(s),1) != "}") s = s "}"
                out = out s
            }
            if (out != "") out = out "," entry
            else out = entry
            print "{\"samples\":[" out "]}"
        }' "$statfile" > "${statfile}.tmp" && mv "${statfile}.tmp" "$statfile"
    fi
}

# ---- daily persistence ------------------------------------------------------

persist_daily_totals() {
    [ -f "$DEVICES_FILE" ] || return
    local today
    today=$(date +%Y-%m-%d)
    while IFS=' ' read -r mac ip hostname; do
        [ -z "$mac" ] && continue
        local safemac
        safemac=$(echo "$mac" | tr -d ':')

        local accfile="$RUNTIME_DIR/daily_acc_${safemac}"
        [ -f "$accfile" ] || continue
        local stored_date stored_down stored_up
        read -r stored_date stored_down stored_up < "$accfile"
        [ "$stored_date" != "$today" ] && continue

        local histfile="$PERSIST_DIR/history_${safemac}.json"
        local entry
        entry=$(printf '{"date":"%s","down":%s,"up":%s}' "$today" "$stored_down" "$stored_up")

        if [ ! -f "$histfile" ]; then
            printf '{"daily":[%s]}\n' "$entry" > "$histfile"
        else
            awk -v today="$today" -v entry="$entry" '
            {
                sub(/\]\}$/, "")
                sub(/^\{"daily":\[/, "")
                n = split($0, arr, /\},\{/)
                found = 0
                out = ""
                for (i=1; i<=n; i++) {
                    s = arr[i]
                    if (substr(s,1,1) != "{") s = "{" s
                    if (substr(s,length(s),1) != "}") s = s "}"
                    if (index(s, "\"date\":\"" today "\"")) { s = entry; found = 1 }
                    if (out != "") out = out ","
                    out = out s
                }
                if (!found) { if (out != "") out = out ","; out = out entry }
                n2 = split(out, arr2, /\},\{/)
                start = (n2 > 90) ? n2 - 89 : 1
                out2 = ""
                for (i=start; i<=n2; i++) {
                    s = arr2[i]
                    if (substr(s,1,1) != "{") s = "{" s
                    if (substr(s,length(s),1) != "}") s = s "}"
                    if (out2 != "") out2 = out2 ","
                    out2 = out2 s
                }
                print "{\"daily\":[" out2 "]}"
            }' "$histfile" > "${histfile}.tmp" && mv "${histfile}.tmp" "$histfile"
        fi
    done < "$DEVICES_FILE"
}

# ---- main loop --------------------------------------------------------------

trap 'log "stopping"; teardown_chains; teardown_chains6; exit 0' TERM INT

WAN_IFACE=$(get_wan_iface)
WAN_IFACE6=$(get_wan_iface6)
log "starting (WAN: ${WAN_IFACE:-unknown}, WAN6: ${WAN_IFACE6:-none})"
teardown_chains
teardown_chains6
setup_chains
setup_chains6

DAILY_FLUSH_HOUR=-1

while true; do
    # Rebuild IPv4 chains if WAN interface changed (e.g. PPPoE reconnect)
    new_wan=$(get_wan_iface)
    if [ "$new_wan" != "$WAN_IFACE" ]; then
        log "WAN interface changed: '${WAN_IFACE}' -> '${new_wan:-unknown}', rebuilding chains"
        teardown_chains
        WAN_IFACE="$new_wan"
        setup_chains
    fi

    # Rebuild IPv6 chains if WAN6 interface changed
    new_wan6=$(get_wan_iface6)
    if [ "$new_wan6" != "$WAN_IFACE6" ]; then
        log "WAN6 interface changed: '${WAN_IFACE6}' -> '${new_wan6:-none}', rebuilding ip6 chains"
        teardown_chains6
        WAN_IFACE6="$new_wan6"
        setup_chains6
    fi

    # Refresh ARP snapshot, update known device registry, add iptables rules
    get_arp_devices > "$RUNTIME_DIR/arp_snapshot"
    while IFS=' ' read -r ip mac; do
        [ -n "$ip" ] && ensure_rules_for_ip "$ip"
    done < "$RUNTIME_DIR/arp_snapshot"
    update_known_devices

    # Refresh NDP snapshot, add ip6tables rules for each global IPv6 address
    get_ndp_devices > "$RUNTIME_DIR/ndp_snapshot"
    while IFS=' ' read -r ip6 mac; do
        [ -n "$ip6" ] && ensure_rules_for_ip6 "$ip6"
    done < "$RUNTIME_DIR/ndp_snapshot"

    write_current_json

    # Zero per-interval counters so next read gives a delta
    iptables  -t mangle -Z "$CHAIN_IN"  2>/dev/null
    iptables  -t mangle -Z "$CHAIN_OUT" 2>/dev/null
    ip6tables -t mangle -Z "$CHAIN_IN"  2>/dev/null
    ip6tables -t mangle -Z "$CHAIN_OUT" 2>/dev/null

    # Persist daily totals once per hour (on the hour)
    current_hour=$(date +%H | sed 's/^0//')
    if [ "$current_hour" != "$DAILY_FLUSH_HOUR" ]; then
        persist_daily_totals
        DAILY_FLUSH_HOUR="$current_hour"
    fi

    sleep "$INTERVAL"
done
