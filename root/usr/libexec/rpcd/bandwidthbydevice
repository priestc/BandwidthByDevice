#!/bin/sh

case "$1" in
  list)
    printf '{"devices":{},"stats":{"mac":"String"},"history":{"mac":"String"},"get_backup_config":{},"set_backup_config":{"protocol":"String","host":"String","port":"String","username":"String","password":"String","remote_path":"String"},"run_backup":{},"run_restore":{},"get_backup_status":{}}\n'
    ;;
  call)
    # rpcd passes method params via stdin as JSON, not as $3
    INPUT=$(cat)

    case "$2" in

      devices)
        cat /tmp/bandwidthbydevice/current.json 2>/dev/null || \
          printf '{"ts":0,"devices":[]}\n'
        ;;

      stats)
        safemac=$(echo "$INPUT" | jsonfilter -e '@.mac' 2>/dev/null | tr -d ':')
        [ -n "$safemac" ] && \
          cat "/tmp/bandwidthbydevice/stats_${safemac}.json" 2>/dev/null || \
          printf '{"samples":[]}\n'
        ;;

      history)
        safemac=$(echo "$INPUT" | jsonfilter -e '@.mac' 2>/dev/null | tr -d ':')
        [ -n "$safemac" ] && \
          cat "/etc/bandwidthbydevice/history_${safemac}.json" 2>/dev/null || \
          printf '{"daily":[]}\n'
        ;;

      get_backup_config)
        printf '{"protocol":"%s","host":"%s","port":"%s","username":"%s","remote_path":"%s"}\n' \
          "$(uci -q get bandwidthbydevice.backup.protocol  || echo sftp)" \
          "$(uci -q get bandwidthbydevice.backup.host      || echo '')" \
          "$(uci -q get bandwidthbydevice.backup.port      || echo 22)" \
          "$(uci -q get bandwidthbydevice.backup.username  || echo '')" \
          "$(uci -q get bandwidthbydevice.backup.remote_path || echo '/backup/bandwidthbydevice')"
        ;;

      set_backup_config)
        uci -q get bandwidthbydevice.backup >/dev/null 2>&1 || \
          uci set bandwidthbydevice.backup=backup
        for key in protocol host port username password remote_path; do
          val=$(echo "$INPUT" | jsonfilter -e "@.${key}" 2>/dev/null)
          [ -n "$val" ] && uci set "bandwidthbydevice.backup.${key}=${val}"
        done
        uci commit bandwidthbydevice
        printf '{"result":"ok"}\n'
        ;;

      run_backup)
        /usr/bin/bbd-backup backup >/dev/null 2>&1
        cat /tmp/bandwidthbydevice/backup_status.json 2>/dev/null || \
          printf '{"status":"error","message":"Script produced no output","ts":0}\n'
        ;;

      run_restore)
        /usr/bin/bbd-backup restore >/dev/null 2>&1
        cat /tmp/bandwidthbydevice/backup_status.json 2>/dev/null || \
          printf '{"status":"error","message":"Script produced no output","ts":0}\n'
        ;;

      get_backup_status)
        cat /tmp/bandwidthbydevice/backup_status.json 2>/dev/null || \
          printf '{"status":"never","message":"No backup has been run yet","ts":0}\n'
        ;;

      *)
        printf '{"error":"unknown method"}\n'
        ;;
    esac
    ;;
esac
