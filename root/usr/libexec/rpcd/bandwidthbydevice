#!/bin/sh

case "$1" in
  list)
    printf '{"devices":{},"stats":{"mac":"String"},"history":{"mac":"String"},"get_backup_config":{},"set_backup_config":{"host":"String","port":"String","username":"String","password":"String","remote_path":"String","auto_backup":"String"},"run_backup":{},"get_backup_status":{},"get_storage_info":{},"set_interval":{"interval":"String"}}\n'
    ;;
  call)
    # rpcd passes method params via stdin as JSON, not as $3
    INPUT=$(cat)

    case "$2" in

      devices)
        # CPU usage: delta between successive /proc/stat reads so we get
        # an accurate percentage for whatever interval the client is polling at.
        _cpu_prev="/tmp/bandwidthbydevice/cpu_stat_prev"
        set -- $(head -1 /proc/stat)
        shift  # drop "cpu" label; $1=user $2=nice $3=system $4=idle $5=iowait $6=irq $7=softirq $8=steal
        _active=$(($1 + $2 + $3 + $6 + $7 + ${8:-0}))
        _total=$((_active + $4 + $5))
        _cpu_pct=0
        if [ -f "$_cpu_prev" ]; then
          read -r _pt _pa < "$_cpu_prev"
          _dt=$((_total  - _pt))
          _da=$((_active - _pa))
          [ "$_dt" -gt 0 ] && _cpu_pct=$(awk "BEGIN{printf \"%d\", $_da*100/$_dt}")
        fi
        printf '%d %d\n' "$_total" "$_active" > "$_cpu_prev"
        _json=$(cat /tmp/bandwidthbydevice/current.json 2>/dev/null)
        if [ -n "$_json" ]; then
          printf '{"cpu_pct":%d,%s\n' "$_cpu_pct" "${_json#\{}"
        else
          printf '{"cpu_pct":%d,"ts":0,"devices":[]}\n' "$_cpu_pct"
        fi
        ;;

      stats)
        safemac=$(echo "$INPUT" | jsonfilter -e '@.mac' 2>/dev/null | tr -d ':')
        [ -n "$safemac" ] && \
          cat "/tmp/bandwidthbydevice/stats_${safemac}.json" 2>/dev/null || \
          printf '{"samples":[]}\n'
        ;;

      history)
        safemac=$(echo "$INPUT" | jsonfilter -e '@.mac' 2>/dev/null | tr -d ':')
        [ -n "$safemac" ] && \
          cat "/etc/bandwidthbydevice/history_${safemac}.json" 2>/dev/null || \
          printf '{"daily":[]}\n'
        ;;

      get_backup_config)
        printf '{"host":"%s","port":"%s","username":"%s","remote_path":"%s","auto_backup":"%s"}\n' \
          "$(uci -q get bandwidthbydevice.backup.host        || echo '')" \
          "$(uci -q get bandwidthbydevice.backup.port        || echo 22)" \
          "$(uci -q get bandwidthbydevice.backup.username    || echo '')" \
          "$(uci -q get bandwidthbydevice.backup.remote_path || echo '')" \
          "$(uci -q get bandwidthbydevice.backup.auto_backup || echo '0')"
        ;;

      set_backup_config)
        uci -q get bandwidthbydevice.backup >/dev/null 2>&1 || \
          uci set bandwidthbydevice.backup=backup
        for key in host port username password remote_path; do
          val=$(echo "$INPUT" | jsonfilter -e "@.${key}" 2>/dev/null)
          if [ -n "$val" ]; then
            uci set "bandwidthbydevice.backup.${key}=${val}"
          elif [ "$key" = "remote_path" ]; then
            uci -q delete "bandwidthbydevice.backup.remote_path"
          fi
        done
        auto_backup=$(echo "$INPUT" | jsonfilter -e '@.auto_backup' 2>/dev/null)
        uci set "bandwidthbydevice.backup.auto_backup=${auto_backup:-0}"
        if [ "$auto_backup" = "1" ]; then
          mkdir -p /etc/crontabs
          grep -qF 'bbd-backup hourly' /etc/crontabs/root 2>/dev/null || \
            printf '0 * * * * /usr/bin/bbd-backup hourly\n' >> /etc/crontabs/root
          /etc/init.d/cron enable 2>/dev/null
          /etc/init.d/cron reload 2>/dev/null || /etc/init.d/cron start 2>/dev/null
        else
          sed -i '/\/usr\/bin\/bbd-backup/d' /etc/crontabs/root 2>/dev/null
          /etc/init.d/cron reload 2>/dev/null
        fi
        uci commit bandwidthbydevice
        printf '{"result":"ok"}\n'
        ;;

      run_backup)
        /usr/bin/bbd-backup hourly >/dev/null 2>&1
        cat /tmp/bandwidthbydevice/backup_status.json 2>/dev/null || \
          printf '{"status":"error","message":"Script produced no output","ts":0}\n'
        ;;

      get_backup_status)
        cat /tmp/bandwidthbydevice/backup_status.json 2>/dev/null || \
          printf '{"status":"never","message":"No backup has been run yet","ts":0}\n'
        ;;

      get_storage_info)
        _buf="/tmp/bandwidthbydevice/persist_buf.jsonl"
        _buf_size=0; _buf_lines=0; _buf_start=0; _buf_end=0
        if [ -f "$_buf" ]; then
          _buf_size=$(wc -c < "$_buf" 2>/dev/null || echo 0)
          _buf_lines=$(wc -l < "$_buf" 2>/dev/null || echo 0)
          if [ "${_buf_lines:-0}" -gt 0 ]; then
            _buf_start=$(awk 'NR==1{split($0,a,"\"ts\":"); split(a[2],b,","); print b[1]+0; exit}' "$_buf" 2>/dev/null)
            _buf_end=$(tail -1 "$_buf" 2>/dev/null | awk '{split($0,a,"\"ts\":"); split(a[2],b,","); print b[1]+0}' 2>/dev/null)
          fi
        fi
        _sum_size=0; _sum_count=0
        for _f in /etc/bandwidthbydevice/persist_summary_*.json; do
          [ -f "$_f" ] || continue
          _sz=$(wc -c < "$_f" 2>/dev/null || echo 0)
          _sum_size=$((_sum_size + _sz))
          _sum_count=$((_sum_count + 1))
        done
        _interval=$(uci -q get bandwidthbydevice.sampling.interval 2>/dev/null || echo 10)
        _limit_kb=$(uci -q get bandwidthbydevice.persist.buf_limit_kb 2>/dev/null || echo 2048)
        printf '{"buf_size":%d,"buf_lines":%d,"buf_start_ts":%d,"buf_end_ts":%d,"summary_size":%d,"summary_count":%d,"interval":%d,"buf_limit_kb":%d}\n' \
          "${_buf_size:-0}" "${_buf_lines:-0}" "${_buf_start:-0}" "${_buf_end:-0}" \
          "${_sum_size:-0}" "${_sum_count:-0}" "${_interval:-10}" "${_limit_kb:-2048}"
        ;;

      set_interval)
        _interval=$(echo "$INPUT" | jsonfilter -e '@.interval' 2>/dev/null)
        if [ -n "$_interval" ]; then
          uci -q get bandwidthbydevice.sampling >/dev/null 2>&1 || \
            uci set bandwidthbydevice.sampling=sampling
          uci set "bandwidthbydevice.sampling.interval=${_interval}"
          uci commit bandwidthbydevice
          printf '%d\n' "$_interval" > /tmp/bandwidthbydevice/interval
          printf '{"result":"ok"}\n'
        else
          printf '{"result":"error","message":"missing interval"}\n'
        fi
        ;;

      *)
        printf '{"error":"unknown method"}\n'
        ;;
    esac
    ;;
esac
